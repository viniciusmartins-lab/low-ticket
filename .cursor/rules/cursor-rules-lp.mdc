## IMPLEMENTAÇÃO DO FORMULÁRIO

```jsx
const handleSubmit = async (e) => {
  e.preventDefault();
  if (!validate()) return;
  setLoading(true);
  try {
    const ok = await sendLead(formData);
    if (ok) {
      trackEvent('generate_lead', { form_name: 'main_form' });
      fbq?.('track', 'Lead');
      setStatus('success');
      resetForm();
    } else {
      setStatus('error');
    }
  } catch {
    setStatus('error');
  } finally {
    setLoading(false);
  }
};
```

